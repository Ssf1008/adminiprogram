<view class="container">
  <view class="card" wx:if="{{stats}}">
    <view class="section-title">统计概览</view>
    <view class="grid">
      <view>
        <view class="label">训练次数</view>
        <view class="value">{{stats.trainCount}}</view>
      </view>
      <view>
        <view class="label">总时长</view>
        <view class="value">{{stats.totalDuration}} 秒</view>
      </view>
      <view>
        <view class="label">平均得分</view>
        <view class="value">{{stats.avgScore}}</view>
      </view>
      <view>
        <view class="label">正确率</view>
        <view class="value">{{stats.avgAccuracy}}%</view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="analysis-top">
      <view class="section-title">AI 训练建议</view>
      <button class="analysis-btn" bindtap="generateAnalysis" disabled="{{analysisLoading}}">
        {{analysisLoading ? '生成中...' : (analysis ? '重新生成' : '生成建议')}}
      </button>
    </view>

    <view class="analysis-tip {{analysisLoading ? 'is-loading' : ''}}">{{analysisTip}}</view>

    <view class="analysis-box {{analysisLoading && analysis ? 'is-refreshing' : ''}}">
      <block wx:if="{{analysis}}">
        <view class="analysis-score">综合评分：{{analysis.overallScore}}</view>
        <view class="analysis-summary">{{analysis.summary}}</view>

        <view class="analysis-section">
          <view class="analysis-label">表现亮点</view>
          <view class="analysis-item" wx:for="{{analysis.strengths}}" wx:key="index">• {{item}}</view>
        </view>

        <view class="analysis-section">
          <view class="analysis-label">关注点</view>
          <view class="analysis-item" wx:for="{{analysis.risks}}" wx:key="index">• {{item}}</view>
        </view>

        <view class="analysis-section">
          <view class="analysis-label">训练建议</view>
          <view class="analysis-item" wx:for="{{analysis.suggestions}}" wx:key="index">• {{item}}</view>
        </view>
      </block>

      <block wx:else>
        <view class="analysis-empty">
          <view class="analysis-empty-line short"></view>
          <view class="analysis-empty-line"></view>
          <view class="analysis-empty-line"></view>
        </view>
      </block>
    </view>
  </view>

  <view class="card" wx:for="{{records}}" wx:key="id">
    <view class="record-top">
      <view class="record-name">{{item.gameName}}</view>
      <view class="record-score">{{item.score}} 分</view>
    </view>
    <view class="muted">训练时长：{{item.duration}} 秒</view>
    <view class="muted">完成度：{{item.completionRate}}% ｜ 正确率：{{item.accuracyRate}}%</view>
    <view class="muted">训练时间：{{item.recordTime}}</view>
  </view>
</view>

