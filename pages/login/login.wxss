.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 40rpx 28rpx 80rpx;
  box-sizing: border-box;
}

.checking-box {
  margin-top: 220rpx;
  text-align: center;
  color: #8b6a46;
  font-size: 30rpx;
}

.hero {
  width: 100%;
  max-width: 100%;
  padding: 42rpx 30rpx;
  background: linear-gradient(180deg, rgba(255, 249, 237, 0.98), rgba(255, 241, 216, 0.95));
  box-sizing: border-box;
}

.badge {
  display: inline-block;
  background: #fff1d2;
  color: #ab6426;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  margin-bottom: 22rpx;
}

.title {
  font-size: 68rpx;
  color: #5b3514;
  font-weight: 800;
  margin-bottom: 18rpx;
}

.subtitle {
  font-size: 30rpx;
  line-height: 1.8;
  color: #715638;
  margin-bottom: 28rpx;
}

.auth-panel {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  width: 100%;
}

.avatar-button,
.nickname-block {
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

.avatar-button {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 18rpx;
  background: #fff7eb;
  border: 2rpx solid #efcf9f;
  border-radius: 24rpx;
  padding: 20rpx 22rpx;
  line-height: normal;
  text-align: left;
}

.avatar-button::after {
  border: none;
}

.avatar-shell,
.avatar-placeholder {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.avatar-preview {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 4rpx solid #efc283;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f3e2c0;
  color: #9d6c38;
  font-size: 28rpx;
  font-weight: 700;
}

.avatar-text {
  color: #7a5227;
  font-size: 30rpx;
  font-weight: 600;
}

.nickname-block {
  background: #fff7eb;
  border: 2rpx solid #efcf9f;
  border-radius: 24rpx;
  padding: 22rpx;
}

.nickname-label {
  color: #7a5227;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.nickname-hint {
  color: #a07d52;
  font-size: 24rpx;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.nickname-input {
  margin-top: 0;
  width: 100%;
  min-height: 88rpx;
  box-sizing: border-box;
  padding: 0 22rpx;
  background: #fffdf8;
  border: 2rpx solid #f0dbb7;
  border-radius: 18rpx;
  font-size: 30rpx;
  color: #5c3a19;
}

.login-btn {
  margin-top: 24rpx;
}

.tip {
  margin-top: 20rpx;
  line-height: 1.7;
}
