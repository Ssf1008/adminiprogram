<view class="container">
  <view class="card profile-head">
    <view wx:if="{{form.avatar}}" class="profile-avatar-shell">
      <image class="profile-avatar" src="{{form.avatar}}" mode="aspectFill"></image>
    </view>
    <view wx:else class="profile-avatar profile-placeholder">头像</view>
    <view class="profile-name">{{form.nickname || '微信用户'}}</view>
    <view class="muted">当前登录账号资料</view>
  </view>

  <view class="card">
    <view class="section-title">个人信息</view>
    <view class="field">
      <view class="label">昵称</view>
      <input class="input" value="{{form.nickname}}" data-key="nickname" bindinput="updateField" />
    </view>
    <view class="field">
      <view class="label">年龄</view>
      <input class="input" type="number" value="{{form.age}}" data-key="age" bindinput="updateField" />
    </view>
    <view class="field">
      <view class="label">手机号</view>
      <input class="input" type="number" value="{{form.phone}}" data-key="phone" bindinput="updateField" />
    </view>
    <view class="field">
      <view class="label">病史</view>
      <textarea class="input" auto-height value="{{form.medicalHistory}}" data-key="medicalHistory" bindinput="updateField"></textarea>
    </view>
    <view class="field">
      <view class="label">家族病史</view>
      <textarea class="input" auto-height value="{{form.familyHistory}}" data-key="familyHistory" bindinput="updateField"></textarea>
    </view>
    <button class="primary-btn" bindtap="save">保存资料</button>
    <button class="secondary-btn logout-btn" bindtap="logout">退出登录</button>
  </view>
</view>
