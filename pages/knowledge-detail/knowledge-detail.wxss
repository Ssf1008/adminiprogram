.detail-card {
  overflow: hidden;
  border-radius: 28rpx;
  background: #fffaf2;
  box-shadow: 0 12rpx 28rpx rgba(140, 100, 52, 0.08);
}

.detail-cover-wrap {
  height: 300rpx;
}

.detail-cover {
  width: 100%;
  height: 300rpx;
  display: block;
  background: linear-gradient(135deg, #f0dfc2, #e6c18f);
}

.fallback-cover {
  height: 300rpx;
  padding: 36rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  background:
    radial-gradient(circle at top right, rgba(255, 248, 234, 0.85), transparent 34%),
    linear-gradient(135deg, #8a5a2c, #c57a31 68%, #efc37f);
  color: #fff8ef;
}

.fallback-title {
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.4;
}

.fallback-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(255, 248, 239, 0.86);
}

.detail-body {
  padding: 30rpx;
}

.detail-title {
  font-size: 40rpx;
  line-height: 1.4;
  font-weight: 800;
  color: #5b3617;
}

.detail-summary {
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: #a4652c;
  font-weight: 700;
}

.detail-content {
  margin-top: 24rpx;
  font-size: 30rpx;
  line-height: 1.9;
  color: #6c553e;
  white-space: pre-wrap;
}

